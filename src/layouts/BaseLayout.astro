---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/styles.css';

interface Props {
  title: string;
  description?: string;
  netlifyIdentity?: boolean;
  headExtra?: string;
}

const { title, description, netlifyIdentity = false, headExtra } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    {netlifyIdentity && <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>}
    {headExtra && <Fragment set:html={headExtra} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="/js/main.js" is:inline></script>
    {netlifyIdentity && (
      <script is:inline>
        if (window.netlifyIdentity) {
          window.netlifyIdentity.on('init', function (user) {
            if (!user) {
              window.netlifyIdentity.on('login', function () {
                document.location.href = '/admin/';
              });
            }
          });
        }
      </script>
    )}
  </body>
</html>
