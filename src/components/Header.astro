---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/',        label: 'Главная' },
  { href: '/catalog', label: 'Каталог' },
  { href: '/about',   label: 'О нас' },
  { href: '/blog/',   label: 'Блог' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">Мастера лозы</a>
    <button class="nav-toggle" aria-label="Открыть меню" aria-expanded="false" aria-controls="site-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Основная навигация">
      <ul>
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={isActive(href) ? 'is-active' : undefined}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
